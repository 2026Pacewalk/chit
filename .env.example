# Copy this file to .env and fill in the values.

# Database (SQLite file, created automatically by `npx prisma db push`)
DATABASE_URL="file:./dev.db"

# Admin dashboard credentials — use a strong password
ADMIN_EMAIL="admin@chitrangi.com"
ADMIN_PASSWORD=""

# Secret used to sign admin session cookies — use a long random string
# (e.g. run: node -e "console.log(crypto.randomBytes(32).toString('hex'))")
SESSION_SECRET=""

# ─── Razorpay (ADD LATER) ────────────────────────────────────────────
# Online payment stays hidden on checkout until BOTH keys are filled in.
# 1. Create an account at https://dashboard.razorpay.com
# 2. Go to Settings → API Keys → Generate Key
# 3. Paste the values below and restart the server — that's it.
#    Checkout will automatically start offering UPI / Cards / Netbanking.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
